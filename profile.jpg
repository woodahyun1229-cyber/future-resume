/* 2147483647 */

#ind-indicator {
  z-index: 2147483647;
  position: fixed;  
  /*
  box-shadow: 0 2px 5px 1px rgba(64,60,67,.16);
  border-radius: 20px;  
  
  box-sizing:content-box !important;
  */
}

.ind-indicator-icon {
  height:20px;
  margin-top:2px;
  pointer-events: none;
  cursor: pointer;
}

.ind-indicator-text {
  line-height: 20px;
  height:20px;  
  margin-left:10px;
  font-size: 14px;
  user-select: none;
  color:#333; 
  cursor: pointer; 
  /*font-family: "Noto Sans KR", sans-serif;*/
}

.cylinder-icon {
  width: 135px;
  height: 40px;
  background-color: #ffffff;
  border-radius: 20px;
  position: relative;
  cursor: move;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon {
  color: #fff;
  margin-right: 5px;
}

.text {
  color: #fff;
}

.cylinder-popup {
  width: 135px;
  background-color: #f8f8f8;
  border-radius: 10px;
  box-shadow: 0 2px 5px 1px rgba(64,60,67,.16);
  position: absolute;
  bottom: calc(100% + 10px);
  right: 0;
  display: none;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: 99999;
}

.popup-item {
  padding: 10px;
  font-size: 14px;
  text-align: center;
  color:#333;
  cursor: pointer;
  /*font-family: "Noto Sans KR", sans-serif;  */
}

.cylinder-popup.show {
  display: block;
  opacity: 1;
}

.ind-button {  
  align-items: center;
  background: transparent;
  border: none;
  padding: 10px 20px;
  border-radius: 50px; /* 실린더 모양을 만들기 위해 테두리를 둥글게 합니다. */
  transition: background 0.2s ease; /* 배경색 변경 시 애니메이션 효과를 주기 위함입니다. */
  cursor: pointer;
}

.ind-button:hover {
  background: #9BA4B5; /* 원하는 배경색으로 변경하세요. */
  color: white; /* 마우스 hover 시 텍스트 색상. 필요에 따라 변경하세요. */
}

.prev {
  position: absolute;
  top: 40%;
  left: 0%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 90px;
  height: 30px;
  opacity: 0.5;
  z-index: 1;  
}

.next {
  position: absolute;
  top: 40%;
  right: 0%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  width: 90px;
  height: 30px;
  opacity: 0.5;
  z-index: 1;  
}

.arrow {
  /*position: absolute;*/
  position: relative;
  top: 20%;
  width: 25px;
  height: 25px;
  /*border-radius: 50%;
  border: solid 1px #ebebeb;
  box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.15);
  */
  /*transform: translateY(-50%);  */
  background-color: #fff;  
  /*opacity: 0.5;*/

  transition: transform 0.3s ease;
  /* transition: opacity 0.3s ease;*/

  display: flex; /* Flex layout 설정 */
  justify-content: flex-start; /* 가로 방향으로 중앙 정렬 */
  align-items: center; /* 세로 방향으로 중앙 정렬 */
  padding-left: 5px;
}

.arrow:hover {
  transform: translateX(-50%); /* 왼쪽으로 50% 이동 */
}

.arrow:hover {
  opacity: 0.7;
  box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.15);
  background-color: #c2e2ff;
  color: black;
  cursor: pointer;
}

.arrow-text {
  padding-left: 5px;
  display: none;
  white-space: nowrap;
}

.arrow:hover .arrow-text {
  display: block;
}

.left-arrow {  
  border-top: 1px solid #ced4da;
  border-left: 1px solid #ced4da;
  width: 60px;
  z-index: 1;  
}

.right-arrow {
  border-top: 1px solid #ced4da;
  border-left: 1px solid #ced4da;
  width: 60px;
  z-index: 1;
}

.img-viewer-arrow-img {
  max-width: 50%; /* 이미지 크기 설정. 필요에 따라 조절하세요. */
  max-height: 50%; /* 이미지 크기 설정. 필요에 따라 조절하세요. */  
  cursor: pointer;
}

#ind-viewer-done-img {
  max-width: 50%; 
  max-height: 50%;
  cursor: pointer;
}

#ind-viewer-done {
  border-top: 1px solid #ced4da;
  border-left: 1px solid #ced4da;
  border-bottom: 1px solid #ced4da;
  width: 60px;
}

/*
#ind-viewer-slider {
  overflow: hidden;
  position: relative;
}
*/

.ind-task-desc {
  display: inline-block; 
  float:left;
  width: 690px;
  justify-content: space-between; 
  padding: 21px;
  text-align: left;
  background:white; 
  height:60px;
  font-size: 14px;
  color:#333;
}

.ind-task-img-container {
  background-color: #f5f5f5;
  overflow: hidden; /* 이미지가 div를 벗어나면 보이지 않도록 합니다. */
  position: relative; /* 이미지 위치 조절을 위해 relative로 설정합니다. */
  /*
  max-height: 600px;
  */
  display: inline-block;

  width: 468px;
  height: 240px;  
}

.ind-task-img {
  /*
  max-width:
  height: 100%;
  object-fit: none; 
  pointer-events:none; 
  */
  height: 100%;  

  max-width: 100%;  
  max-height: 240px; 
  
  object-fit: contain;
  display: block; /* 이미지를 블록 요소로 설정하여 가운데 정렬을 위한 마진을 적용합니다. */
  margin: auto; /* 이미지를 가운데 정렬합니다. */  
  /*
  position: absolute; 
  top: 0;
  left: 0;
  bottom: 0;
  right: 0;
  */
}

.ind-viewer-slide {
  /*display: none;  */
}

.ind-viewer-slide.active {
  display: block;
  
  animation: slide 1s;
}

@keyframes slide-right-in {
  0% {
    transform: translateX(100%);
  }
  100% {
    transform: translateX(0);
  }
}

@keyframes slide-left-in {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(0);
  }
}

@keyframes slide-right-out {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-100%);
  }
}

@keyframes slide-left-out {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(100%);
  }
}

.ind-viewer-slide.active.right-in {
  animation: slide-right-in 0.2s;
}

.ind-viewer-slide.active.left-in {
  animation: slide-left-in 0.2s;
}

.ind-viewer-slide.active.right-out {
  animation: slide-right-out 0.2s;
  position: absolute;
}

.ind-viewer-slide.active.left-out {
  animation: slide-left-out 0.2s;
  position: absolute;
}

.ind-checkbox {
  float:right;
  width: 70px;
  height: 70px;
  margin-right:17px;
  margin-top:17px;
  border: 1px solid #ced4da;
  border-radius: 10px;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
}

.checkmark {
  width: 100%;
  height: 100%;
}

.checkmark path {
  stroke: lightgray; /* 흐릿한 회색 톤으로 V 표시 */
}

.ind-checkbox.active .checkmark path {
  stroke: #ff0063; /* 활성화된 체크박스에 V 체크를 표시 */
}

.ind-help-tooltip {
  display: none;
  position: absolute;
  background: #394867;
  color: #fff;
  padding: 13px;
  border-radius: 20rem;
  top: 135px;
  
  font-size: 11pt;
  box-shadow: 2px 2px 3px #d1d1d1;  
  z-index: 2147483647;
}

.ind-help-tooltip:after {
  bottom: 100%;
  transform: translate(-1px, 3px);
  left: 192px; /* 말풍선 꼬리 */
  border: solid transparent;
  content: " ";
  height: 0;
  width: 0;
  position: absolute;
  pointer-events: none;
  border-color: rgba(56, 77, 157, 0);
  border-bottom-color: #394867;
  border-width: 11px;
  margin-left: -50px;
} 

.checkmark:hover .ind-help-tooltip {
  display: block;
}

.btn-qguider {
  position: absolute;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6px;
  width: 140px;
  height: 40px;
  border-radius: 20px;
  box-shadow: 0 3px 5px 0 rgba(0, 133, 255, 0.15);
  background-color: #0085ff;
  color: #fff;
  border: none;
  outline: none;
  cursor: pointer;
}

.btn-qguider .icon-qguider {
  width: 20px;
  display: inline-block;
  cursor: pointer;
}

.btn-qguider-type2 {
  padding-left:7px;
  padding-top:2px;
  position: absolute;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 50px; 
  height: 50px; 
  border-radius: 20px; 
  box-shadow: rgba(255, 255, 255, 0.2) 0px 0px 0px 1px inset, rgba(0, 0, 0, 0.1) 0px 4px 6px, rgba(0, 0, 0, 0.15) 0px 8px 30px;
  background-color: #0085ff;
  color: #fff;
  border: none;
  outline: none;
  cursor: pointer;
}

.btn-qguider-type2 .icon-qguider-type2 {
  width: 30px;
  display: inline-block;
  cursor: pointer;
}

.icon-qguider-span {
  width: 20px;
}

.icon-qguider-span-type2 {
  width: 30px;
}

.icon-qguider-img {
  width: 100%;
  display: block;
  cursor: pointer;
  pointer-events: none;
}
/*
.btn-qguider span {
  cursor: pointer;
}
*/

.menu-popup {
  display: none;
  position: absolute;    
  bottom: calc(100% + 10px); right: calc(100% - 50px);
  /*bottom: calc(100% + 90px);*/  
  width: 180px;
  border-radius: 6px;
  box-shadow: 0 2px 4px 0 rgba(0, 0, 0, 0.15);
  border: solid 1px #ebebeb;
  background-color: #fff;
  justify-content: center;
  flex-direction: column;
  /*
  align-items: center;  
  */
  z-index: 99999;
  font-family: 'IndPretendard', fallback-font, sans-serif;
}

.menu-popup.active {
  display: flex;
}

.menu-popup .menu {
  width: 100%;
  cursor: pointer;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 15px 0;
  padding-left: 20px;
  border-bottom: 1px solid #ebebeb;
  font-size: 13px;
  color: #333;
}

.menu-popup .menu:hover {
  background-color: #eaeaea;
}

.menu-popup .menu:last-child {
 border-bottom: none; 
}

.menu-popup .menu .icon {
  margin-right: 10px;
  margin-top: 2px;
}

.menu-popup span {
  font-family: 'IndPretendard', fallback-font, sans-serif;
  font-size: 13px;
}

.main-popup.active {
  display: block;
}

.main-popup {
  display: none;
  padding: 16px 20px 3px 16px;
  position: absolute;
  bottom: 90px;
  right: 40px;
  width: 260px;
  border-radius: 4px;
  /*box-shadow: 0 2px 4px 0 rgba(0, 0, 0, 0.15);*/
  box-shadow: 0 0 16px 8px rgba(0, 0, 0, 0.05);
  border-top: 3px solid #0085ff;
  background-color: #fff;
  /*transition: 0.5s;*/
  overflow: hidden;
}

.main-popup.active.min {
  display: flex;
}
.main-popup.min {
  width: 60px;
  padding: 17px 0 10px;
  display: none;
  justify-content: center;
  align-items: center;
  overflow: visible;
}
.main-popup.min .top-area {margin-bottom: 0;}
.main-popup.min .top-area .tit {display: none;}
.main-popup.min .search-area {display: none;}
.main-popup.min .list-area {display: none;}
.main-popup.min .step-area {display: none;}
.main-popup.min .top-area .icon-box {
  height: 100%;
  flex-direction: column-reverse;
  display: flex;
  gap: 20px;
  justify-content: center;
  align-items: center;
}

.main-popup.min .top-area .icon-box .size-btn {transform: rotate(180deg);}
.main-popup.min .top-area .icon-box .logo-btn {display: block;}
.main-popup.min .top-area .icon-box .play-btn {display: block;}

.main-popup .step-percent {display: none;}
.main-popup.min .step-percent {display: block;}

.main-popup .step-min-area {display: none;}
.main-popup.min .step-min-area {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow-y: scroll;
  /* overflow: auto; */
}
.main-popup.min .step-min-area {
  -ms-overflow-style: none; /* IE and Edge */
  scrollbar-width: none; /* Firefox */
}
.main-popup.min .step-min-area::-webkit-scrollbar {
  display: none; /* Chrome, Safari, Opera*/
}

.main-popup.min .step-percent {
  font-size: 15px;
  font-weight: bold;
  color: #0085ff;
} 

.main-popup.min .step-min-area .line {
  width: 100%;
  height: 165px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
}
.main-popup.min .step-min-area .line .step {
  position: relative;
  cursor: pointer;
  z-index: 1;
}
.main-popup.min .step-min-area .line .step::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  z-index: -1;
  /*
  background-color: #d9d9d9;
  */
  background-color: red;
  height: 46px;
  width: 3px;
}

.main-popup.min .step-min-area .line .step:last-child::after {
  top: 0%;
}

.main-popup.min .step-min-area .line .step img {display: none;}
.main-popup.min .step-min-area .line .step img:nth-child(1) {display: block;}
.main-popup.min .step-min-area .line .step.complete img:nth-child(1) {display: none;}
.main-popup.min .step-min-area .line .step.complete img:nth-child(2) {display: block;}

.main-popup.min .step-min-area .step-box {
  position: relative;
}
.main-popup.min .step-min-area .bubble-area {
  display: none;
  position: absolute;
  top: -10px;
  right: 45px;
  width: 210px;
  padding: 15px;
  box-shadow: 0 2px 4px 0 rgba(0, 0, 0, 0.15);
  border: 1px solid  #c2e8ff;
  background-color: #e0f3ff;
  /* z-index: 999; */
}
.main-popup.min .step-min-area .line .step .bubble-area::before {
	content: '';
	position: absolute;
	right: 0;
	top: 20%;
	width: 0;
	height: 0;
	border: 9px solid transparent;
	border-left-color: #e0f3ff;
	border-right: 0;
	margin-top: -9px;
	margin-right: -9px;
}

.main-popup.min .step-min-area .line .step .bubble-area .step-num {
  display: inline-block;
  font-size: 10px;
  font-weight: bold;
  color: #0085ff;
  margin-bottom: 4px;
}
.main-popup.min .step-min-area .line .step .bubble-area .step-tit {
  font-size: 12px;
  font-weight: 500;
  color: #110809;
  margin-bottom: 8px;
}
.main-popup.min .step-min-area .line .step .bubble-area .step-txt {
  color: #878787;
  font-size: 13px;
}

.main-popup .top-area {
  display: flex;
  margin-bottom: 20px;
  align-items: center;
  justify-content: space-between;
}
.main-popup .top-area .tit {
  color: #110809;
  font-size: 15px;
  font-weight: bold;
  white-space : nowrap; 
}
.main-popup .top-area .tit .btn-back {
  display: inline-block;  
  cursor: pointer;
}
.main-popup .top-area .tit .btn-back i {
  color: #a1a1a1;
}

.main-popup .top-area .icon-box {
  display: flex;
  gap: 14px;
}
.main-popup .top-area .icon-box .size-btn {
  cursor: pointer;
  width: 16px;
  display: block;
}
.main-popup .top-area .icon-box .close-btn {
  cursor: pointer;
  width: 14px;
  display: block;
}
.main-popup .top-area .icon-box .play-btn {
  cursor: pointer;
  width: 18px;
  display: none;
}
.main-popup .top-area .icon-box .logo-btn {
  cursor: pointer;
  width: 40px;
  display: none;
}
.main-popup .top-area .icon-box .size-btn img {width: 100%; display: block;}
.main-popup .top-area .icon-box .close-btn img {width: 100%; display: block;}

.main-popup .search-area {
  margin-bottom: 10px;
}
.main-popup .search-area .search {
  position: relative;
}
.main-popup .search-area .search input {
  width: 100%;
  height: 40px;
  padding: 0 50px 0 10px;
  border-radius: 6px;
  border: solid 1px #ebebeb;
  background-color: #fff;
  color: black;
  outline: none;
  
}
.main-popup .search-area .search .icon-search {
  position: absolute;
  top: 55%;
  transform: translateY(-50%);
  right: 20px;
  cursor: pointer;
}

.main-popup .list-area {
  padding-right: 5px;
  overflow-y: scroll;
  overflow-x: hidden;
  height: 280px;
  width: 235px;
}

.main-popup .list-area::-webkit-scrollbar {
  width: 4px;
}

.main-popup .list-area::-webkit-scrollbar-thumb {
  height: 120px; 
  background: #a0a0a0;
  border-radius: 12px;
}

.main-popup .list-area::-webkit-scrollbar-track {
  background-color: #eaeaea;
}

.main-popup .list-area .list-no {
  color: #110809;
  font-size: 13px;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  white-space: nowrap;
}

.main-popup .list-area .list {
  padding: 15px 0 15px;
  min-height: 30px;
  border-bottom: 1px solid #ebebeb;
  cursor: pointer;
  align-items: center;
}
.main-popup .list-area .list:first-child {margin-top: 0px;} /* 수정 */

.main-popup .list-area .list:hover .tit {
  text-decoration: underline;
}
.main-popup .list-area .list:hover .txt {
  text-decoration: underline;
}


.main-popup .list-area .list .tit {
  color: #110809;
  font-size: 14px;
  /*margin-bottom: 8px;*/
}
.main-popup .list-area .list .txt {
  font-size: 12px;
  color: #878787;
  line-height: 1.2;
}

.main-popup .step-area {
  margin-top: 7px;  
}

.main-popup .step-area .step-top {
  height: 290px;
  /*
  display: flex;  
  gap: 32px;
  padding-bottom: 20px;
  height: 277px;
  width: 100%;
  */

  /*
  overflow-y: hidden;
  overflow-x: hidden;
  */
}

.main-popup .step-area .step-top .step-scroll {
  display: flex;
  gap: 32px;
  padding-bottom: 20px;
  height: 277px;
  /*width: 100%;*/
  overflow-y: auto;  
  overflow-x: hidden;
}

.main-popup .step-area::-webkit-scrollbar {
  width: 4px;
}

.main-popup .step-area::-webkit-scrollbar-thumb {
  height: 120px; 
  background: #a0a0a0;
  border-radius: 12px;
}

.main-popup .step-area::-webkit-scrollbar-track {
  background-color: #eaeaea;
}

.main-popup .step-area .step-top .step-line {
  height: 100%;
}
/* .main-popup .step-area .step-top .step-line .line{
  height: 100%;
  width: 3px;
  background-color: #d9d9d9;
} */


.main-popup .step-area .step-box .step {
  margin-bottom: 30px;
  position: relative;
  cursor: pointer;
}
.main-popup .step-area .step-box .step:last-child {
  padding-bottom: 10px;
}

.main-popup .step-area .step-box .step .step-icon {
  position: absolute;
  left: -23%;
  top: 0;
  transform: translateX(50%);
  z-index: 100;
}
.main-popup .step-area .step-box .step .step-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  /*
  transform: translate(-50%,-50%);
  */
  transform: translate(-50%,0%);
  z-index: -1;
  width: 3px;
  min-height: 145px;
  max-height: 400px;

  background-color: #d9d9d9;
  /*
  background-color: red;
  */
}


.main-popup .step-area .step-scroll .step-box .step .step-icon svg {display: none;}
.main-popup .step-area .step-scroll .step-box .step .step-icon svg:nth-child(1) {display: block;}
.main-popup .step-area .step-scroll .step-box .step.complete .step-icon svg {display: none;}
.main-popup .step-area .step-scroll .step-box .step.complete .step-icon svg:nth-child(1) {display: none;}
.main-popup .step-area .step-scroll .step-box .step.complete .step-icon svg:last-child {display: block;}

.main-popup .step-area .step-scroll .step-box .step:last-child {
  margin-bottom: 3px;
}

.main-popup .step-area .step-scroll .step-box .step .step-num {
  display: inline-block;
  font-size: 10px;
  color: #0085ff;
  font-weight: bold;
  margin-bottom: 4px;
}
.main-popup .step-area .step-scroll .step-box .step .step-tit {
  font-size: 12px;
  font-weight: 500;
  margin-bottom: 8px;
  /*
  white-space : nowrap; 
  */
  width:180px;
  color: #110809;
}
.main-popup .step-area .step-scroll .step-box .step .step-txt {
  font-size: 13px;
  color: #878787;
  width:180px;
  line-height: 1.3;
}
.main-popup .step-area .btn-step-close {
  border-radius: 4px;
  border: solid 1px #0085ff;
  background-color: #fff;
  width: 100%;
  height: 40px;
  font-size: 13px;
  color: #0085ff;
  margin-bottom: 20px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6px;
  cursor: pointer;
}


}

#ind-image-editor-canvas-base,
#ind-image-editor-canvas {
  /*position: absolute;*/
}

#ind-editor-content-title {  
  font-size: 12px;
  left: 30px; 
  width:250px;   
  vertical-align: text-top; 
  text-align: left;
  color:black;
  pointer-events: none;
  line-height: 28px;
  white-space: nowrap;
}

#ind-list-container-site-label {
  line-height: 28px;
  color: black;
}

.ind-list-toolbar {
  position:relative; 
  display:flex;  
  align-items: center;
  justify-content: flex-start;  
  padding: 8px;
}

.ind-list-body {
  display: flex;
  height: 100%;
}

.ind-list-body .tags {
  width: 30%;
}

.ind-list-body .guides {
  width: 100%;
}

.ind-button {  
  align-items: center;
  background: transparent;
  border: none;
  padding: 7px 15px;
  border-radius: 7px; /* 실린더 모양을 만들기 위해 테두리를 둥글게 합니다. */
  transition: background 0.2s ease; /* 배경색 변경 시 애니메이션 효과를 주기 위함입니다. */
  cursor: pointer;
}

.ind-button:hover {
  background: #0085ff; /* 원하는 배경색으로 변경하세요. */
  color: white; /* 마우스 hover 시 텍스트 색상. 필요에 따라 변경하세요. */
}

#ind-config-toggle-min-img {
  cursor: pointer;
}

#ind-list-toggle-min-img {
  cursor: pointer;
}

#ind-share-guide-close {
  cursor: pointer;
}

#ind-image-editor-open {
  cursor: pointer;
}

.ind-editor-h_holder {
  display:flex;
  justify-content: space-between;
}

#ind-editor-content-add {
  cursor:pointer;
}

#ind-text-editor {
  display: none;
  box-sizing: content-box !important;
  position: absolute;
  left:-2093029302;
  top: 0px;
  width:800px;     
  
  font-family: "Noto Sans KR", sans-serif;
  font-size: 12px;
  text-align: center;
  border-radius: 7px;
  box-shadow: 0 2px 5px 1px rgba(64,60,67,.16);
  background-color: #383838;
  color: #f0f0f0;  
  background: white;
}

.ind-confirm-dialog {
  display: none;
  position: absolute;
  width: 250px;
  height: 130px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: white;
  border-top: 3px solid #0085ff;
  border-radius: 4px;
  box-shadow: 0 2px 4px 0 rgba(0, 0, 0, 0.15);
  z-index: 2001;
}

.ind-confirm-dialog .ind-header {
  position: relative;
  display: block;
  width: 100%;
  height: 5px;
  background-color: white;
}

.ind-confirm-dialog .ind-title {
  display: flex;
  width: 100%;
  height: 50px;
  align-items: center;
  justify-content: center;
  padding: 16px;  
}

.ind-confirm-dialog .ind-title-text {
  font-size: 13px;
  line-height: 1.2;
}

.ind-confirm-dialog .ind-button-area {
  display: flex;
  width: 100%;
  height: 50px;
  align-items: center;
  justify-content:space-around;
  margin-top: 15px;
}

.ind-confirm-dialog .ind-button-area .button-yes {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 14px;
  color: #fff;
  width: 60px;
  height: 30px;
  border-radius: 4px;
  background-color: #0085ff;
  cursor: pointer;
}

.ind-confirm-dialog .ind-button-area .button-no {
  cursor: pointer;
  width: 60px;
}

#ind-editor-toggle-add-img {
  cursor: pointer;
}

#ind-related-guide {
  margin-right: 5px;
}

#ind-related-guide-add-img {
  cursor: pointer;
}

#ind-related-guide-remove-img {
  cursor: pointer;
}

.ind-editor-body .txt-line {
  display: block;
  line-height: 28px;
  font-size: 12px;

}

.gif-bottom-group .button-group {
  display: none;
}

.gif-bottom-group .wait-message {
  display: block;
  color: black;
}

.gif-bottom-group.done .button-group {
  display: block;
}

.gif-bottom-group.done .wait-message {
  display: none;
}

.tabs {
  display: flex;
  gap: 20px;
  align-items: center;
}

.tab-header {
  font-size: 12px;
  cursor: pointer;
  padding-left: 8px;
  padding-right: 8px;
  line-height: 28px;
}

.tab-header.active {
  background-color: #f5f5f5;
}

.tab-page {
  /*
  overflow-y: auto;
  */
  height: 480px;
  display: none;
}

.tab-page.active {
  display: block;
}

.bottom-row {
  position: absolute;
  display: flex; 
  justify-content: center;
  align-items: center;
  bottom: 0px;
  width: 50%;
  height: 49px;
  background:white;
  border-top: 1px solid #ced4da;
}

.tab-page::-webkit-scrollbar {
  width: 8px; /* 스크롤 바의 너비 설정 */
}

/* 스크롤바 트랙(경로) */
.tab-page::-webkit-scrollbar-track {
  background: transparent;
}

/* 스크롤바 핸들(슬라이더) */
.tab-page::-webkit-scrollbar-thumb {
  height: 30%;
  /* 스크롤바의 길이 */
  background: #ced4da;
  /* 스크롤바의 색상 */
}

.tab-page .section {
  padding: 8px;
}

.row-content {
  line-height: 28px;
}

.input-field:focus {
  outline: 1.2px solid #0085ff;
}

.list-container {
  width: 100%;
  height: 118px;
  border-top: 1px solid #ced4da;
  border-bottom: 1px solid #ced4da;
}

.list-item {
  display: flex;
  align-items: center;
  line-height: 28px;
  padding: 8px 8px 0px 8px;
}

.list-text {
  width: 100%;
  padding-left: 8px;
  padding-right: 8px;
}

.list-toggle {
  width: 20px !important;
  height: 20px !important;
}

.list-button {
  background: transparent;
  border: none;
  width: 28px;
  height: 28px;  
}

.list-button:hover {
  background: #f5f5f5;
  cursor: pointer;
}

/* Tooltip container */
.ind-tooltip {
  display: inline-block;
}

/* Tooltip text */
.ind-tooltip .ind-tooltiptext {
  visibility: hidden;
  width: 120px;
  background-color: black;
  color: white;
  text-align: center;
  border-radius: 6px;
  padding: 5px 0;

  /* Position the tooltip text */
  position: absolute;
  z-index: 2147483648;
  top: 15%;
  left: 50%;
  margin-left: -60px;
}

/* Show the tooltip text when you mouse over the tooltip container */
.ind-tooltip:hover .ind-tooltiptext {
  visibility: visible;
}

#ind-grid-pos-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr); /* 3개의 열 생성 */
  grid-template-rows: repeat(3, 1fr); /* 3개의 행 생성 */  
  box-sizing: border-box;
  width: 100%;
  height: 118px;
  border-top: 1px solid #ced4da;
  border-bottom: 1px solid #ced4da;
  gap: 8px;
  padding: 8px;
  justify-items: center; /* 그리드 아이템들을 수평 방향으로 가운데 정렬 */
  align-items: center; /* 그리드 아이템들을 수직 방향으로 가운데 정렬 */
}

.grid-item {
  border: 1px solid #ced4da; /* 구분을 위한 경계선 추가 */
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background-color 0.3s; /* 배경색 변화에 애니메이션 효과 */
  height: 28px;
  width: 28px;
}

.grid-item.active {
  background-color: #0085ff; /* 활성 상태의 배경색 */
}

.ind-img-icon {
  width:22px; 
  height:22px;     
  cursor: pointer;  
}


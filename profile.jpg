  margin-bottom: 10px;
}

.start-popup .btn-area {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-top:auto;
}

.start-popup .btn-area span {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 14px;
  color: #fff;
  width: 120px;
  height: 40px;
  border-radius: 4px;
  background-color: #0085ff;
  cursor: pointer;
}

.start-popup .btn-area span:first-child {

  /*
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  */
  top: calc(50vh - 138.5px); /* 277px / 2 */
  left: calc(50vw - 200px); /* 400px / 2 */
  width: 400px;
  height: 277px;
  border-radius: 8px;
  /*box-shadow: 0 2px 4px 0 rgba(0, 0, 0, 0.15);*/
  box-shadow:
  0px 0px 9.3px rgba(0, 0, 0, 0.095),
  0px 0px 74px rgba(0, 0, 0, 0.19);
  background-color: #fff;
  border-top: 8px solid #0085ff;
  padding: 20px 20px 20px 20px;
  z-index: 2147483645;           
}

.start-popup .tit {
  font-size: 18px;
  font-weight: bold;
  color: #0085ff;
  margin-bottom: 20px;

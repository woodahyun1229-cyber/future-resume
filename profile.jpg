  all: initial;
  height: 20px;
  cursor: pointer;
}
*/
#ind-title {
  text-align: left;
  display: inline-block;
  margin: 0 auto;
}

#ind-toggle {
  all: initial;
  width: 20px;
  height: 23px;
  top: 7px;
}

.ind-config-toggle {
  all: initial;
  cursor: pointer;
  width: 20px;
  height: 20px;
  margin-right: 5px;
}

.ind-minimize-toggle {
  all: initial;
  cursor: pointer;
  width: 20px;
  height: 20px;
}

.ind-search-top {
  all: initial;
  display: inline-block;
  height: 45px;
  width: 100%;
  border-bottom: 1px solid #ced4da;
}

#ind-main #ind-search-input {

선택</button></div></div></div></div><div id="dgtroad-qguider" style="display: block;"><template shadowrootmode="open"><style>* {
  box-sizing: border-box; 
  font-family: var(--ind-font-family) !important;
  font-size: 13px;
}
/*
body, div, ul, li, dl, dd, dt, ol, h1, h2, h3, h4, h5, h6, input, fieldset, legend, p, select, table, th, td, tr, textarea, button, form, figure, figcaption {margin:0; padding:0;}
*/

#ind-main::-webkit-scrollbar {
  width: 8px;
  /* 스크롤바의 너비 */
}

#ind-main::-webkit-scrollbar-thumb {
  height: 30%;
  /* 스크롤바의 길이 */
  background: #ced4da;
  /* 스크롤바의 색상 */

  border-radius: 10px;
}

#ind-main::-webkit-scrollbar-track {
  background: #f1f1f1;
  /*스크롤바 뒷 배경 색상*/
}

#ind-scroll-container {
  cursor: pointer;
}

#ind-scroll-container::-webkit-scrollbar {
  width: 4px;
  /* 스크롤바의 너비 */
}

#ind-scroll-container::-webkit-scrollbar-thumb {
  height: 120px; 
  background: #a0a0a0;
  border-radius: 12px;
}

#ind-scroll-container::-webkit-scrollbar-track {
  background-color: #eaeaea;
}

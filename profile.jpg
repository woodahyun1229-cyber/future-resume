.ind-list-context-menu {
  display: none; /* Initially hidden */
  position: absolute; /* To position it correctly */
  /* Add more styling here */  
  left: 470px;
  top: 90px;
  width: 120px;  
  border: 1px solid gray;
  z-index: 1;
  background-color: white;
}

.ind-list-context-menu .menu {
  display: flex;
  align-items: center;
  line-height: 30px;
}


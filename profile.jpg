  font-size: 1em;
  line-height: 1.2;
  padding: 0.5em var(--padding-x);
  border-width: 1px;
  border-style: solid;
}
*/

#ind-search-button {
  all: initial;
  display: inline-block;
  background-color: transparent;
  border-width: 0;
  color: #333333;
  cursor: pointer;
  display: inline-block;
  /*
  font-family: "Haas Grot Text R Web", "Helvetica Neue", Helvetica, Arial,
    sans-serif;
  */
  font-size: 12px;
  font-weight: 500;
  line-height: 12px;
  list-style: none;
  margin: 0;
  margin-left: 10px;
  margin-bottom: 3px;
  text-align: center;
  transition: all 200ms;
  vertical-align: middle;
  white-space: nowrap;
  user-select: none;
  -webkit-user-select: none;
  touch-action: manipulation;

  display: inline-flex;
  justify-content: center;
  /* center the content horizontally */
  align-items: center;
  /* center the content vertically */
  --padding-x: 1.2em;
  border-color: transparent;
  /* hide button border */
  /*font-family: "Noto Sans KR", sans-serif;*/
}

.ind-search-button-img:hover {
  cursor: pointer;
}

.ind-search-button-img {
  all: initial;
  vertical-align: middle;
  width: 23px;
  height: 23px;
}

.ind-vertical-list {
  all: initial;
  width: 200px;
  /* Set a width if you like */
  height: 150px;
  /*overflow-y: scroll;*/
  position: relative;
  background: grah;
}

.ind-vertical-child {
  min-height: 80px;
  padding: 10px;

  border-radius: 4px;
  border: 1px solid white;
  cursor: pointer;

  display: -webkit-box;
  word-wrap: break-word;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  text-overflow: ellipsis;
  overflow: hidden;
}

.ind-vertical-child.active,
.ind-vertical-child:hover {
  background-color: #f7f7f7;
  border-radius: 4px;
  border: 1px solid #ced4da;
  cursor: pointer;
}

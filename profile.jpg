#ind-editor input {
  all: initial;
  width: 100%; /* Full width */
  padding: 7px; /* Some padding */
  border: 1px solid #ccc; /* Gray border */
  border-radius: 4px; /* Rounded borders */
  box-sizing: border-box; /* Make sure that padding and width stays in place */
  margin-top: 6px; /* Add a top margin */
  margin-bottom: 16px; /* Bottom margin */
  resize: vertical; /* Allow the user to vertically resize the textarea (not horizontally) */
  font-size: 12px !important;
  /*font-family: "Noto Sans KR", sans-serif;*/
  color: gray;
}

#ind-main-content {
  all: initial;
  padding: 10px;
  width: 100%;
  height: 100%;
  background: white;
  /*font-family: "Noto Sans KR", sans-serif;*/
}

#ind-message-dialog-back {
  all: initial;
  width: 100%;
  height: 100%;
  position: absolute;
  background: black;
  z-index: inherit;
  opacity: 0.3;
}

#ind-message-dialog {
  all: initial;
  width: 80%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 1px solid #000000;
  background: white;
  z-index: inherit;
  border-radius: 10px;
  padding: 30px 0;
  text-align: center;
  /*font-family: "Noto Sans KR", sans-serif;*/
}

.ind-main-info {
  all: initial;
  width: 100%;
  height: 230px;
  justify-content: center;
  /*font-family: "Noto Sans KR", sans-serif;*/
  text-align: center;
}

#ind-main .ind-main-info-p {
  width: 100%;
  display: flex;
  justify-content: center;
  /*font-family: "Noto Sans KR", sans-serif;*/
  text-align: center;
  margin-top: 20px;
}

.ind-main-button {
  all: initial;
  width: 100%;
  display: flex;
  justify-content: center;
}

.ind-main-login {
  all: initial;
  display: inline-block;
  margin: 10px;
  /*font-family: "Noto Sans KR", sans-serif;*/
}

.ind-main-login:hover {
  all: initial;
  display: inline-block;
  margin: 10px;
  cursor: pointer;
  /*font-family: "Noto Sans KR", sans-serif;*/
}

.ind-main-signup {
  all: initial;
  display: inline-block;
  margin: 10px;
  /*font-family: "Noto Sans KR", sans-serif;*/
}

.ind-main-signup:hover {
  all: initial;
  display: inline-block;
  margin: 10px;
  cursor: pointer;
  /*font-family: "Noto Sans KR", sans-serif;*/
}

#ind-header {
  /*display: flex;
  justify-content: space-between;*/

  /*
  position: relative;
  height: 28px;
  */
}

#ind-back {  
  cursor: pointer;
}


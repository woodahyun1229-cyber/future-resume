.reason-list {
  display: grid;
  gap: 8px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.reason {
  position: relative;
  display: flex;
  align-items: center;
  gap: var(--gap);
  padding: var(--item-padding);
  border-radius: var(--item-radius);
  cursor: pointer;
  transition: background-color .15s ease;
}

.reason:hover {
  background: var(--item-hover);
}

.reason.active {
  background: var(--item-active);
}

/* 아이콘 */
.reason .icon {
  width: var(--icon-size);
  height: var(--icon-size);
  flex-shrink: 0;
}

/* 보조 텍스트 */

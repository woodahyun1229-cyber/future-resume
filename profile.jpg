.ind-row {
  justify-content: space-between;
  display: flex;
  margin-bottom: 8px;
}

.ind-vertical-page-item-left {
  cursor: pointer;
  display: inline-block;
  /*font-family: "Noto Sans KR", sans-serif;*/
  font-size: 14px;
  width: 100%;
}

#ind-main .ind-title-text {
  all: initial;
  display: inline-block;
  /*font-family: "Noto Sans KR", sans-serif;*/
  position: relative;
  height: 100%;
}

.ind-title-text:hover {
  all: initial;
  display: inline-block;
  /*font-family: "Noto Sans KR", sans-serif;*/
  cursor: move;
  height: 100%;
}

.ind-skip-button {
  color: white;
  border-color: white;
}

.ind-next-button {
  color: white;
  border-color: white;
}

.ind-vertical-item-picker {
  all: initial;
  text-decoration: none;
  font-size: 13px;
  color: gray;
  /*font-family: "Noto Sans KR", sans-serif;*/
  cursor: pointer;
}

.ind-vertical-item-picker:hover {
  all: initial;
  cursor: pointer;
  text-decoration: none;
  font-size: 13px;
  color: darkturquoise;
  /*font-family: "Noto Sans KR", sans-serif;*/
}

#ind-main-img-hidden {
  display: none;
}

#ind-main .ind-task-action-checked {
  filter: sepia(100%);
}

.ind-task-actions {
  all: initial;
  width: 20px;
  height: 20px;
  margin-top: -5px;  
  display: none;
}


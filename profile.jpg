.ind-vertical-content-child {
  min-height: 110px;
  padding: 10px;
  font-size: 14px;
  border-radius: 4px;
  border: 1px solid white;
  cursor: pointer;

  display: -webkit-box;
  word-wrap: break-word;
  -webkit-line-clamp: 3;

.swiper-button-next, .swiper-button-prev {
  top: 65% !important;
  transform: translateY(-50%);
}

.swiper-button-next, .swiper-button-prev {
  color: #a1a1a1 !important;
  width: 50px !important;
  height: 50px !important;
  box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.15);
  border: solid 1px #ebebeb;
  background-color: #fff;
  border-radius: 50%;
  z-index: 999 !important;
}
.swiper {
  position: relative;
}
.swiper-button-prev:hover {
  opacity: 0.6;
  box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.15);
  background-color: #c2e2ff;
}

.swiper-button-next:hover {
  opacity: 0.6;
  box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.15);
  background-color: #c2e2ff;
}

.swiper-button-next, .swiper-rtl .swiper-button-prev {
  right: 8px !important;
}
.swiper-button-prev, .swiper-rtl .swiper-button-next {
  left: 8px !important;
}

.swiper-button-next:after, .swiper-button-prev:after {
  font-size: 16px !important;
}
.swiper-button-next:hover:after, .swiper-button-prev:hover:after {
  font-size: 16px !important;
  color: #0085ff !important;
}

.swiper-button-next.swiper-button-disabled, .swiper-button-prev.swiper-button-disabled {
  /* opacity: 1 !important; */
}

.swiper-wrapper {
  min-height: 300px;
}

#ind-loader-overlay {
  display: none;
  position: fixed; /* 화면에 고정 */
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2147483647; /* 다른 모든 요소 위에 위치하도록 가장 높은 z-index 값을 설정 */
  pointer-events: all; /* 다른 요소들과 상호작용을 방해하지 않음 */
  align-items: center; /* 세로 중앙 정렬 */
  justify-content: center; /* 가로 중앙 정렬 */
  background-color: rgba(0, 0, 0, 0.1); /* 배경을 반투명 검은색으로 설정 */
}

/* 'active' 클래스가 추가되면 로더를 표시합니다. */
#ind-loader-overlay.active {
  display: flex;
}

#ind-loader-content {
  width: 100px;
  height: 100px;
  z-index: 2147483647; /* 확실하게 최상위에 있도록 z-index 설정 */
  background-color: rgba(0, 0, 0, 0.0);; /* 배경색을 흰색으로 설정 */
  /*
  border: 1px solid #cccccc; 
  border-radius: 10px; 
  */
  /* 이미지가 전체 div를 채우도록 설정합니다. */
  display: flex; 
  justify-content: center;
  align-items: center;
  pointer-events: auto;
}

#ind-loader-content img {
  width: 100%; /* 이미지가 div의 크기에 맞게 조정됩니다. */
  height: auto;
}

#dgtroad-end-line {
  position: fixed;
  bottom: 0;
  right: 0;
  width: 1px;
  height: 1px;
  background-color: transparent;
  z-index: 2147483647; /* Ensure it is on top of everything */
}

.ind-viewer-scale-context-menu {
  display: none; /* Initially hidden */
  position: absolute; /* To position it correctly */
  /* Add more styling here */
  right: 38px;
  top: 40px;
  width: 100px;  
  border: 1px solid #ebebeb;
  z-index: 10;
  background-color: white;
}

.ind-viewer-scale-context-menu .menu {
  display: flex;
  align-items: center;
  line-height: 30px; 
}

.ind-viewer-scale-context-menu .menu:hover {
  background-color:#ced4da;
  color:white;
  cursor: pointer;
}

.ind-viewer-scale-context-menu .item {
  display: flex;
  width: 100%;
  line-height: 30px;
}

.ind-viewer-scale-context-menu .item input {
  margin: 8px;
  width: 80px;
  border: 1px solid #ebebeb;
}

.ind-viewer-scale-context-menu .text {
  width: 100%;
  height: 100%;
  /*margin: 0px 10px;*/
  padding: 0px 10px;
  vertical-align: -webkit-baseline-middle;  
  color: black;
}

.ind-viewer-scale-context-menu .text:hover {
  color: white;
}

.animated-circle {
  width: 35px; /* 원의 크기 */
  height: 35px; /* 원의 크기 */
  border-radius: 50%; /* 원 모양 */
  /* border: 4px solid rgba(0, 133, 255, 0.2); */
  /* animation: border-fade 1s infinite; */
  animation: box-shadow-fade 1s infinite;
}

/* @keyframes를 사용한 테두리 색상 투명도 애니메이션 정의 */
@keyframes border-fade {
  0%, 100% {
    border-color: rgba(0, 133, 255, 0.2);
    border-width: 1px;
  }
  50% {
    border-color: rgba(0, 133, 255, 1);
    border-width: 4px;
  }
}

@keyframes spin {
  from {
    transform: scale(0.7) rotateY(0deg);
  }
  to {
    transform: scale(0.7) rotateY(360deg);
  }
}

@keyframes box-shadow-fade {
  0%, 100% {
    box-shadow: 0 0 10px rgba(0, 133, 255, 0.2);
  }
  50% {
    box-shadow: 0 0 10px rgba(0, 133, 255, 1);
  }
}

#ind-viewer-current-scale { 
  font-size: 12px;
  color: #777;
}

#ind-viewer-checkbox {
  z-index: 200;
  position: absolute;
  left: 94%;
  top: 90%;

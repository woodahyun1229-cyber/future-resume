  overflow-x: hidden; 
  height:520px;
  padding: 8px;
  background:#F1F6F9; 
  border-radius: 7px;
}

#ind-grid-container:hover {
  overflow-y: scroll; 
}

#ind-grid-container::-webkit-scrollbar {
  width: 7px;
  /* 스크롤바의 너비 */
}

#ind-grid-container::-webkit-scrollbar-thumb {
  height: 30%;
  /* 스크롤바의 길이 */
  background: #ced4da;
  /* 스크롤바의 색상 */
}

#ind-grid-container::-webkit-scrollbar-track {
  background: transparent;
  /*스크롤바 뒷 배경 색상*/
}

#ind-editor img {
  filter: none !important;
}


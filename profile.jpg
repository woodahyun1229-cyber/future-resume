}

.ind-list-context-menu .text {
  width: 100%;
  height: 100%;
  /*margin: 0px 10px;*/
  padding: 0px 10px;
  vertical-align: -webkit-baseline-middle;
  text-align: left;
}

#ind-editor-sites {
  margin-left: 16px;
  height: 28px;
  width: 230px;
  border: 1px solid #ced4da;
}

#ind-editor select:focus {
  outline: none;

}

#ind-editor option {
  all: initial;
  font-size: 12px;
  font-family: "Noto Sans KR", sans-serif;
  color: gray;
}

#ind-editor #ind-editor-datatable body {
  all: initial;
  display: table-row-group;
  vertical-align: middle;
  border-color: gray;

  font-size: 12px !important;
  font-family: "Noto Sans KR", sans-serif;
  color: gray;
}

#ind-editor #ind-editor-datatable thead {
  display: table-header-group;
  vertical-align: middle;
  border-color: gray;
  border-bottom: 1px solid !important;
  margin-bottom: 1px !important;

  font-size: 12px !important;
  font-family: "Noto Sans KR", sans-serif;
  color: gray;
}

#ind-editor #ind-editor-datatable th {
  border-left: 0px !important;

  font-size: 12px !important;
  font-family: "Noto Sans KR", sans-serif;
  color: gray;

  display: table-cell !important;
  vertical-align: inherit !important;

  line-height: 20px !important;
}

#ind-editor #ind-editor-datatable tr {
  border-top: 0px !important;
  display: table-row !important;

  font-size: 12px !important;
  font-family: "Noto Sans KR", sans-serif;
  color: gray;

  text-align: center !important;
}

#ind-editor #ind-editor-datatable tr:hover {
  background-color: rgba(245, 245, 245, 1) !important;
}

#ind-editor #ind-editor-datatable td {
  border-left: 0px !important;
  border-bottom: 0px !important;
  padding: 8px 10px !important;
  box-sizing: content-box !important;

  text-align: left !important;
  display: table-cell !important;
  vertical-align: middle !important;

  height: 25px !important;
}

#ind-editor .ind-icon-button {
  width:20px; 
  height:20px;     
  cursor: pointer;  
}

/*
#ind-editor #ind-editor-back-img {  
  cursor: pointer;
  width:20px !important;
  height:20px !important;
}
*/

#ind-editor table {
  border-top: 1px !important;
  border-bottom: 1px !important;
  border-left: 0px !important;
  border-right: 0px !important;
}

#ind-editor .mdc-data-table__cell {
  cursor: pointer;

  border: 1px !important;
  font-weight: 100 !important;
  line-height: 10px !important;
  font-size: 12px !important;
  font-family: "Noto Sans KR", sans-serif;
  color: gray;

  height: 25px !important;
}

#ind-editor-container {
  overflow: hidden;
  display: flex;
  width: 608px;
  height: 100%;
  box-sizing: content-box !important;
  cursor: default;
}

#ind-list-container {
  /*
  width:100%;
  height:400px;  
  padding: 5px 0px 5px 0px;  
  */
  padding: 0px; 
  box-sizing: content-box !important; 
  width: 100%;
  cursor: default;

  /*
  overflow: hidden;  
  width: 598px;
  height: 564px;
  */
}

#ind-list-container-header {
  display:block;   
  border-bottom: 1px solid #ced4da;
  padding: 8px;
}

#ind-list-container-header .h-box {
  display:flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px;
}

#ind-editor-toggle-min-img-front {
  margin-left:4px;
}

#ind-list-container-header-label {  
  font-size: 12px;
  float:left; 
  color:black;
  pointer-events: none; 
  line-height: 28px;
}

#ind-list-container-group-label {  
  width:100%; 
  vertical-align: top; 
  color: black;
  line-height: 28px;
}

#ind-list-container-guide-label {   
  width:70%; 
  vertical-align: top; 
  color: black;
  line-height: 28px;
}

#ind-list-tags {
  display: inline-block;   
  width:30%;  
  padding:7px; 
  /*
  margin-left:7px; 
  */
  vertical-align: top; 
  border:1px solid #ced4da; 
  border-left: none;
  /*
  border-radius: 7px;
  */
}

#ind-list-tags .h-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 2px 8px;
}

#ind-editor-tags {
  height: 290px;
}

#ind-list-content {
  display: inline-block; 
  /*margin-left:7px;   */
  width:70%;
  padding:8px; 
  border:1px solid #ced4da;
  border-right: none;
  border-left: none;
  vertical-align: top; 
}

#ind-list-content .h-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 2px 8px;
}

#ind-list-bottom {
  display: flex;
  float:right; 
  height:40px; 
  line-height:40px; 
  margin-right:10px; 
  margin-top: 10px;   
  justify-content: right;     
}


#ind-editor #ind-guide-add {
  all: initial;
  cursor: pointer;
}

#ind-editor #ind-guide-publish {
  cursor: pointer;
  width: 100px;
  text-align: center;
}

#ind-editor .ind-img-container {
  all: initial;
  display: flex;
  justify-content: center;
  align-items: center;
}

#ind-editor .ind-img-items {
  all: initial;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  flex-wrap: wrap;
  width: 100%;
}

#ind-editor .ind-img-item {
  all: initial;
  height: 200px;
  width: 200px;

  margin: 5px;
  box-shadow: 1px 2px 5px #536a72;
  border: 1px solid gray;
}

#ind-editor .ind-img {
  all: initial;
  width: 200px;
  height: 200px;
  object-fit: cover;
}

#ind-editor-capture-image {
  all: initial;
  width: 100%;
  height: 140px;
  border: none;
  object-fit: contain;
}

#ind-editor-preview {
  position: relative;
  width: 100%;
  height: 142px;
  box-sizing: border-box;  
  display: flex; 
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-top: 1px solid #ced4da; 
  border-bottom: 1px solid #ced4da; 
  /*
  border-radius: 7px;  
  */
}

#ind-editor-preview .ind-open {
  display: none;
}

#ind-editor-preview:hover .ind-open {
  display: block;
  position:absolute; 
  right:10px;   
  top: 7px;   /* 상단으로 정렬 */
  margin: 7px 0px 0px 0px;
  border: 1px solid #333;
  border-radius: 5px;
  background: white;
}

#ind-editor-preview-dropzone {
  position: absolute;
  width: 100%;
  height: 100%; 
  display: flex;
  flex-direction: column;  
  justify-content: center;
  align-items: center;  
}

.drop-highlight {
  border: 2px dashed #27374D;
  border-radius: 7px;
}

.ind-editor-preview-mp4-message {
  position: relative;
  margin-top: 60px;
  margin-bottom: 60px;
  width: 100%;
  text-align: center;
  font-size: 14px;
  color: white; /* 글자 색상 설정 */
  text-shadow: -1px -1px 0 #333,  /* top left */
                1px -1px 0 #333,   /* top right */
                -1px 1px 0 #333,   /* bottom left */
                1px 1px 0 #333;    /* bottom right */
}

.ind-editor-preview-message {  
  position: relative;  
  margin-top: 60px;  
  margin-bottom: 60px;
  width: 100%;   
  text-align: center;
  font-size: 14px;
  color: black; /* 글자 색상 설정 */
  text-shadow: -1px -1px 0 #ffffff,  /* top left */
                1px -1px 0 #ffffff,   /* top right */
                -1px 1px 0 #ffffff,   /* bottom left */
                1px 1px 0 #ffffff;    /* bottom right */
  cursor: pointer;
}

#ind-editor .ind-image-capture {
  all: initial;
  cursor: pointer;
  width: 25px;
  height: 25px;
  display: inline-block;
  vertical-align: middle;
}

.ind-editor-right-bottom {  
  display: flex;  
  justify-content: center;  
}

#ind-guide-new-text {
  cursor: pointer; 
  width:100px; 
  height:32px; 
  text-align: center;
}

#ind-guide-update-text {
  cursor: pointer; 
  width:100px; 
  height:32px; text-align: center; display: none;
}

#ind-guide-preview {
  cursor: pointer; 
  width:100px; 
  height:32px; text-align: center;
}

#ind-guide-publish {
  cursor: pointer; 
  width:100px; 
  height:40px; 
  text-align: 
  center; 
  display: none
}

.you-custom-theme-class .margin {
  background-color: blue;
}

.you-custom-theme-class .border {
  background-color: red;
}

.you-custom-theme-class .padding {
  background-color: green;
}

.you-custom-theme-class .content {
  background-color: gray;
}

#ind-editor #sortable-div {
  margin-top: 5px;
}

#ind-editor .ind-sortable-list {
  overflow-y: scroll;
}

#ind-editor .ind-sortable-item {
  height: 50px;
  border-radius: 7px;
  border: 1px solid #ced4da;
  margin-left: 10px;
  margin: 5px;
}

#ind-editor .ind-grid {
  width: 100%;
  position: relative;
  min-height: 100%;
  height: calc(100vh - 90px);
  display: none;
}

#ind-editor .ind-grid.active {
  display: block;
}

#ind-editor .ind-item {
  position: absolute;
  width: 300px;
  height: 40px;
  line-height: 10px;
  margin: 5px;
  z-index: 1;
}

.ind-item.muuri-item-hidden {
  z-index: 0;
}

.ind-item.muuri-item-positioning {
  z-index: 2;
}

.ind-item.muuri-item-releasing {
  z-index: 3;
}

.ind-item.muuri-item-dragging {
  z-index: 4;
}

.ind-item-content {
  position: relative;
  width: 100%;
  height: 100%;
  text-align: center;
  background: red;
  font-size: 12px;
  color: white;
  cursor: pointer;
}

.ind-item.muuri-item-dragging .ind-item-content {
  background: blue;
}

.ind-item.muuri-item-releasing .ind-item-content {
  background: blueViolet;
}

.board-item {
  position: absolute;
  width: calc(100% - 16px);
  margin: 8px;
}

.board-item.muuri-item-releasing {
  z-index: 9998;
}

.board-item.muuri-item-dragging {
  z-index: 9999;
  cursor: move;
}

.board-item.muuri-item-hidden {
  z-index: 0;
}

.board-item-content {  
  min-height: 20px;
  position: relative;
  padding: 20px;
  background: #fff;
  border-radius: 7px;
  font-size: 12px;
  cursor: pointer;
  -webkit-box-shadow: 0px 1px 3px 0 rgba(0, 0, 0, 0.2);
  box-shadow: 0px 1px 3px 0 rgba(0, 0, 0, 0.2);
}

.board-item.active {
  border: 1px solid #0085ff;
  border-radius: 7px;
}

.board-item:hover {
  /*
  background-color: #f7f7f7;
  
  */
  /*border: 1px solid #212A3E;*/  

  /*
  -webkit-box-shadow: 1px 1px 3px 1px rgba(0, 0, 0, 0.2);
  box-shadow: 1px 1px 3px 1px rgba(0, 0, 0, 0.2);
  */
}

.board-item .ind-drag-handle {
  position: absolute;
  top: calc(50% - 10px) !important;
  left: 10px;
}

.ind-drag-handle img {
  width: 20px !important;
  height: 20px !important;
}

.ind-guide-remove {
  width: 20px !important;
  height: 20px !important;
}

.board-item .nested {
  position: absolute;
  top: 10px;
  right: 10px;
  display: none;
}

.board-item.active:hover .nested {
  display: block;
}

.ind-guide-title-seq {    
  display: inline-block;
  color: black;
  font-size: 12px;
  font-family: "Noto Sans KR", sans-serif;
  line-height: 1;
}

.ind-guide-title-span {  
  cursor: pointer;
  width: 180px;
  white-space: nowrap;
  overflow: hidden;
  vertical-align: middle;
  text-overflow: ellipsis;
  display: inline-block;
  color: black;
  font-size: 12px;
  font-family: "Noto Sans KR", sans-serif;
  line-height: 14px;
}

/*
@media (max-width: 600px) {
  .board-item-content {
    text-align: center;
  }
  .board-item-content span {
    display: none;
  }
}
*/

#ind-editor .ind-toast {
  all: initial;
  min-width: 100px;
  min-height: 20px;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translateX(-50%);
  /*margin-left: -100px;*/
  /*bottom: 10px;*/
  background-color: #383838;
  color: #f0f0f0;
  font-family: "Noto Sans KR", sans-serif;
  font-size: 12px;
  line-height: 1.4;
  padding: 10px;
  text-align: center;
  border-radius: 7px;

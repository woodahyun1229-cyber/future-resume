.ind-editor-dim {
  display: none;
  width:100%;
  height: 100%;
  position: absolute;
  pointer-events: bounding-box;
  background-color: black;
  opacity: 0.3;
  z-index: 1000;
}

#ind-editor .hiddenblockslide {
  margin-left: 100%;
}

#ind-editor .hiddenblockvisible {
  display: block;
}

#ind-editor .ind-editor-header {
  width: 100%;
  padding: 8px;
  border-bottom: 1px solid #ced4da;
}

#ind-editor .ind-editor-body {
  width: 100%;
  padding: 8px;
}

#ind-editor #ind-editor-title {
  text-align: left;
}

#ind-editor .ind-editor-title-text {
  position: absolute;
  top: 2%;
  left: 10%;
}

#ind-editor .ind-editor-toggle {
  all: initial;
  display: inline-block;
  width: 145px;
  height: 20px;
  text-align: right;
}

#ind-editor .ind-editor-add {
  all: initial;
  cursor: pointer;
  width: 25px;
  height: 25px;
  display: inline-block;
  vertical-align: middle;
  margin: 0px 7px 0px 7px;
}

#ind-editor .ind-editor-label {
  all: initial;
  font-family: "Noto Sans KR", sans-serif;
}

#ind-editor .ind-list-title-input {
  all: initial;
  width: 100%;
  display: inline-block;
  padding: 6px 12px;
  font-size: 12px;
  font-weight: 400;
  line-height: 1;
  color: #212529;
  background-color: #fff;
  background-clip: padding-box;
  border: 1px solid #ced4da;
  appearance: none;
  font-family: "Noto Sans KR", sans-serif;
  transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;  
}

